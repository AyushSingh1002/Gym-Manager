generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipPlan {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  CUSTOM
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  ONLINE
}

enum AdminRole {
  ADMIN
  RECEPTIONIST
}

enum TicketStatus {
  OPEN
  CLOSED
}

enum NotificationType {
  EXPIRY
  PAYMENT
  WORKOUT
  ANNOUNCEMENT
  REMINDER
}

enum FitnessGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  ENDURANCE
  GENERAL_FITNESS
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      AdminRole @default(ADMIN)
  phone     String?
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs  ActivityLog[]
  workoutPlans  WorkoutPlan[]

  @@index([email])
  @@index([role])
}

model Member {
  id              String        @id @default(cuid())
  memberId        String        @unique
  firstName       String
  lastName        String
  email           String?
  phone           String        @unique
  alternatePhone  String?
  password        String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  emergencyName   String?
  emergencyPhone  String?
  emergencyRelation String?
  photo           String?
  notes           String?
  status          MembershipStatus @default(PENDING)
  joinDate        DateTime        @default(now())
  isActive        Boolean         @default(true)

  weight          Float?
  height          Float?
  bmi             Float?
  goal            FitnessGoal?
  fitnessLevel    String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  memberships     Membership[]
  attendance      Attendance[]
  payments        Payment[]
  workoutPlans    WorkoutPlan[]
  progressLogs    ProgressLog[]
  progressPhotos  ProgressPhoto[]
  notifications   Notification[]
  supportTickets  SupportTicket[]

  @@index([memberId])
  @@index([phone])
  @@index([status])
  @@index([isActive])
  @@index([createdAt])
  @@index([joinDate])
}

model Membership {
  id             String           @id @default(cuid())
  memberId       String
  plan           MembershipPlan
  startDate      DateTime
  endDate        DateTime
  status         MembershipStatus @default(ACTIVE)
  amount         Float
  discount       Float            @default(0)
  totalAmount    Float
  paymentStatus  PaymentStatus    @default(PENDING)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  member         Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  payments       Payment[]

  @@index([memberId])
  @@index([status])
  @@index([plan])
  @@index([endDate])
  @@index([startDate])
  @@index([memberId, status])
}

model Attendance {
  id         String   @id @default(cuid())
  memberId   String
  date       DateTime @default(now())
  checkIn    DateTime @default(now())
  checkOut   DateTime?
  type       String   @default("check-in")
  notes      String?
  createdAt  DateTime @default(now())

  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, date])
  @@index([memberId])
  @@index([date])
  @@index([memberId, date])
}

model Payment {
  id             String         @id @default(cuid())
  memberId       String
  membershipId   String?
  amount         Float
  method         PaymentMethod
  status         PaymentStatus  @default(PAID)
  transactionId  String?        @unique
  razorpayOrderId String?
  razorpayPaymentId String?
  receiptNo      String?
  notes          String?
  date           DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  member         Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  membership     Membership?    @relation(fields: [membershipId], references: [id])

  @@index([memberId])
  @@index([status])
  @@index([method])
  @@index([createdAt])
  @@index([razorpayOrderId])
  @@index([memberId, status])
}

model WorkoutPlan {
  id          String   @id @default(cuid())
  memberId    String
  createdBy   String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdByAdmin Admin @relation(fields: [createdBy], references: [id])

  exercises   WorkoutExercise[]

  @@index([memberId])
  @@index([createdBy])
  @@index([isActive])
  @@index([memberId, isActive])
}

model WorkoutExercise {
  id            String  @id @default(cuid())
  workoutPlanId String
  name          String
  sets          Int?
  reps          Int?
  weight        Float?
  restTime      Int?
  dayOfWeek     Int
  order         Int     @default(0)
  notes         String?
  completed     Boolean @default(false)

  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  @@index([workoutPlanId])
  @@index([workoutPlanId, dayOfWeek])
}

model ProgressLog {
  id        String   @id @default(cuid())
  memberId  String
  weight    Float?
  bodyFat   Float?
  chest     Float?
  waist     Float?
  hips      Float?
  arms      Float?
  thighs    Float?
  notes     String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([date])
}

model Notification {
  id        String           @id @default(cuid())
  memberId  String
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  member    Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([read])
  @@index([createdAt])
  @@index([memberId, read])
}

model SupportTicket {
  id          String       @id @default(cuid())
  memberId    String
  subject     String
  message     String
  status      TicketStatus @default(OPEN)
  adminReply  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  member      Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([status])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  admin     Admin?   @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@index([entity, entityId])
}

model Setting {
  id    String @id @default("gym")
  name  String @default("GymFlow")
  tagline String?
  address String?
  phone String?
  email String?
  website String?
  currency String @default("INR")
  timezone String @default("Asia/Kolkata")
  gstNumber String?
  logo String?
  razorpayKeyId String?
  razorpayKeySecret String?
}

model ProgressPhoto {
  id       String @id @default(cuid())
  memberId String
  url      String
  type     String @default("front")
  date     DateTime @default(now())

  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model FAQ {
  id        String  @id @default(cuid())
  question  String
  answer    String
  order     Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([order])
}
